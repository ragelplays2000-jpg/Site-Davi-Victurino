{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "site-davi-victurino",
  "compatibility_date": "2026-05-09",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "exclude": [
      "node_modules",
      ".wrangler",
      ".claude",
      "scripts",
      "*.log",
      ".gitignore",
      "package.json",
      "package-lock.json",
      "wrangler.jsonc"
    ]
  }
}
